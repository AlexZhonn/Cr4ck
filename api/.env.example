# ── Database ──────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (or any PostgreSQL URL)
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── Auth ──────────────────────────────────────────────────────────────────────
# 64-char hex secret used to sign JWT tokens.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend.
ALLOWED_ORIGINS=http://localhost:4200

# ── AI Evaluation ─────────────────────────────────────────────────────────────
# Anthropic API key for Claude code evaluation.
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Redis (optional) ──────────────────────────────────────────────────────────
# Used for caching challenges (5 min TTL) and leaderboard (60s TTL).
# If unset or Redis is unreachable, caching is silently disabled.
REDIS_URL=redis://localhost:6379/0
