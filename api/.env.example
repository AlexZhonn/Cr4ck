# ── Database ──────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (or any PostgreSQL URL)
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── Auth ──────────────────────────────────────────────────────────────────────
# 64-char hex secret used to sign JWT tokens.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend.
ALLOWED_ORIGINS=http://localhost:4200

# ── AI Evaluation (server fallback) ───────────────────────────────────────────
# Optional: server-level Anthropic key used when a user has no personal key set.
# Set ALLOW_SERVER_KEY=false to require users to supply their own key (recommended for prod).
ANTHROPIC_API_KEY=sk-ant-...
ALLOW_SERVER_KEY=true

# ── User API Key Encryption ────────────────────────────────────────────────────
# 64-char hex secret for AES-256-GCM encryption of stored user API keys.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY_SECRET=your-64-char-hex-here

# ── Code Execution (Judge0 CE) ────────────────────────────────────────────────
# URL of your self-hosted Judge0 CE instance.
# If unset, falls back to direct Docker execution (dev only).
# Deploy: https://github.com/judge0/judge0/blob/master/CHANGELOG.md#deployment
# JUDGE0_URL=http://localhost:2358

# ── Email Verification (Postmark) ─────────────────────────────────────────────
# Server API token from your Postmark account dashboard.
# Create a free account at https://postmarkapp.com and add a verified sender.
POSTMARK_API_KEY=your-postmark-server-token
# Verified sender address configured in Postmark (must match your domain).
POSTMARK_FROM=noreply@yourdomain.com
# Base URL of the Angular frontend — used to build the verification link.
FRONTEND_URL=http://localhost:4200

# ── Redis (optional) ──────────────────────────────────────────────────────────
# Used for caching challenges (5 min TTL) and leaderboard (60s TTL).
# If unset or Redis is unreachable, caching is silently disabled.
REDIS_URL=redis://localhost:6379/0

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# DSN from your Sentry project settings. Leave unset to disable crash reporting.
# Create a free account at https://sentry.io and create a Python/FastAPI project.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
