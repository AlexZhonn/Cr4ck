# ── Production environment variables ─────────────────────────────────────────
# Copy to .env on your production server.  Never commit this file with real values.
#
# AUDIT-S4 SECURITY NOTE:
#   ALLOWED_ORIGINS MUST use https:// in production.  The app uses Bearer tokens
#   stored in localStorage; transmitting them over plain HTTP is a security risk.
#   Your Nginx / load-balancer MUST redirect all http:// traffic to https://.
#   See nginx.conf for the recommended redirect block.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
# Connection pool sizing — tune for your Postgres max_connections limit
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<64-char-hex>

# ── CORS — MUST use https:// in production ────────────────────────────────────
ALLOWED_ORIGINS=https://cr4ck.dev

# ── AI Evaluation ─────────────────────────────────────────────────────────────
# Set ALLOW_SERVER_KEY=false to force BYOK (recommended for production)
ANTHROPIC_API_KEY=sk-ant-...
ALLOW_SERVER_KEY=false

# ── User API Key Encryption ────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY_SECRET=<64-char-hex>

# ── Code Execution (Judge0 CE) ────────────────────────────────────────────────
JUDGE0_URL=http://judge0:2358

# ── Email Verification (Postmark) ─────────────────────────────────────────────
POSTMARK_API_KEY=<postmark-server-token>
POSTMARK_FROM=noreply@yourdomain.com
# MUST use https:// so verification links work over HTTPS
FRONTEND_URL=https://cr4ck.dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Observability ─────────────────────────────────────────────────────────────
# Sentry DSN for backend crash reporting (see AUDIT-O2)
# SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>

# ── Admin ─────────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET=<32-char-hex>
